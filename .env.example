# ============================================================
# CourierHub — Bangladesh Courier Integration
# ============================================================
# Copy these variables to your .env file and fill in your
# credentials from each courier's merchant dashboard.
# ============================================================

# Default courier driver (pathao, steadfast, redx, ecourier, paperfly)
COURIER_DEFAULT=pathao

# ============================================================
# PATHAO COURIER
# Get credentials: Merchant Dashboard → Developer API
# ============================================================
COURIER_PATHAO_ENABLED=false
COURIER_PATHAO_SANDBOX=true
COURIER_PATHAO_CLIENT_ID=
COURIER_PATHAO_CLIENT_SECRET=
COURIER_PATHAO_USERNAME=
COURIER_PATHAO_PASSWORD=
COURIER_PATHAO_WEBHOOK_SECRET=

# ============================================================
# STEADFAST COURIER
# Get credentials: Merchant Dashboard → API Section
# ============================================================
COURIER_STEADFAST_ENABLED=false
COURIER_STEADFAST_API_KEY=
COURIER_STEADFAST_SECRET_KEY=
COURIER_STEADFAST_WEBHOOK_SECRET=

# ============================================================
# REDX COURIER
# Get credentials: Merchant Dashboard / Contact Support
# ============================================================
COURIER_REDX_ENABLED=false
COURIER_REDX_SANDBOX=true
COURIER_REDX_ACCESS_TOKEN=
COURIER_REDX_WEBHOOK_SECRET=

# ============================================================
# ECOURIER
# Get credentials: Contact eCourier merchant support
# ============================================================
COURIER_ECOURIER_ENABLED=false
COURIER_ECOURIER_SANDBOX=true
COURIER_ECOURIER_API_KEY=
COURIER_ECOURIER_API_SECRET=
COURIER_ECOURIER_USER_ID=

# ============================================================
# PAPERFLY
# Get credentials: Contact Paperfly account manager
# ============================================================
COURIER_PAPERFLY_ENABLED=false
COURIER_PAPERFLY_USERNAME=
COURIER_PAPERFLY_PASSWORD=
COURIER_PAPERFLY_API_KEY=

# ============================================================
# WEBHOOK (optional)
# ============================================================
COURIER_WEBHOOK_SECRET=

# ============================================================
# CACHE (optional — for city/zone/area lists)
# ============================================================
COURIER_CACHE_ENABLED=true
COURIER_CACHE_TTL=3600
